generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  password               String
  name                   String
  role                   Role                    @default(USER)
  registeredVia          AuthProvider            @default(CREDENTIALS)
  registeredAt           DateTime                @default(now())
  lastAuthProvider       AuthProvider?
  lastAuthAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  articles               Article[]
  comments               Comment[]
  reactions              Reaction[]
  businessesOwned        Business[]
  notificationRecipients NotificationRecipient[]
  deliveryLeads          DeliveryLead[]
  assignedDeliveryLeads  DeliveryLead[]          @relation("DeliveryLeadAssignee")
  defaultFulfillmentAutomationProfiles FulfillmentAutomationProfile[] @relation("FulfillmentAutomationDefaultAssignee")
  affiliateClicks        AffiliateClick[]
  analyticsEvents        AnalyticsEvent[]
  rewardLedgerEntries    RewardLedger[]
  savedProducts          SavedProduct[]
  savedOffers            SavedOffer[]
  experienceProfile      UserExperienceProfile?
  experienceHistory      UserExperienceHistory[]
  savedOfferAlertsEnabled Boolean                 @default(true)
  savedOfferEmailAlertsEnabled Boolean            @default(false)
  authRegistrationEvents AuthRegistrationEvent[]
  authFunnelEvents       AuthFunnelEvent[]
  passwordResetTokens    PasswordResetToken[]
  passwordResetDispatches PasswordResetDispatch[]
}

model UserExperienceProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  profileImageUrl       String?
  activeTheme           String   @default("black")
  activeSkin            String   @default("editorial")
  activeSiteVersion     String   @default("v1")
  activePresetSlug      String?
  savedPresets          Json?
  activeExperiencePackId String?
  personalDigestEnabled Boolean  @default(true)
  digestCadenceHours    Int      @default(168)
  lastDigestAt          DateTime?
  lastSeenAt            DateTime?
  lastSeenPath          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeExperiencePack  ExperiencePack? @relation("UserActiveExperiencePack", fields: [activeExperiencePackId], references: [id], onDelete: SetNull)

  @@index([activeTheme])
  @@index([activeSkin])
  @@index([activeSiteVersion])
  @@index([activePresetSlug])
  @@index([activeExperiencePackId])
  @@index([lastSeenAt])
}

model UserExperienceHistory {
  id            String   @id @default(cuid())
  userId        String
  preferenceKey String
  previousValue String?
  nextValue     String
  sourceContext String?
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, preferenceKey, createdAt])
  @@index([preferenceKey, createdAt])
}

model SiteConfiguration {
  id                 String   @id @default("global")
  homePagePresetSlug String   @default("walnut-rustic-gazette")
  deliveryPaymentConfig Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ExperiencePack {
  id           String                @id @default(cuid())
  slug         String                @unique
  name         String
  description  String?
  coverImageUrl String?
  status       ExperiencePackStatus  @default(DRAFT)
  isSelectable Boolean               @default(false)
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  pages        ExperiencePackPage[]
  activeUsers  UserExperienceProfile[] @relation("UserActiveExperiencePack")

  @@index([status, isSelectable, sortOrder])
  @@index([slug, status])
}

model ExperiencePackPage {
  id               String               @id @default(cuid())
  experiencePackId String
  routeKey         String
  title            String
  notes            String?
  viewportLabel    String?
  imageUrl         String
  originalFilename String?
  fileSizeBytes    Int?
  sortOrder        Int                  @default(0)
  isPublished      Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  experiencePack   ExperiencePack       @relation(fields: [experiencePackId], references: [id], onDelete: Cascade)

  @@unique([experiencePackId, routeKey])
  @@index([routeKey, isPublished])
  @@index([experiencePackId, sortOrder])
}

model Article {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String
  excerpt         String?
  coverUrl        String?
  content         String
  publishedAt     DateTime?
  status          ArticleStatus    @default(DRAFT)
  authorId        String?
  likeCount       Int              @default(0)
  wowCount        Int              @default(0)
  hmmCount        Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  author          User?            @relation(fields: [authorId], references: [id])
  comments        Comment[]
  reactions       Reaction[]
  affiliateClicks AffiliateClick[]
  analyticsEvents AnalyticsEvent[]
  reviewProfile   ReviewProfile?
  commerceModules ArticleCommerceModule[]
}

model ReviewProfile {
  id                    String    @id @default(cuid())
  articleId             String    @unique
  productId             String?
  productName           String
  brandName             String?
  category              String?
  reviewScore           Int?
  verdict               String?
  organicStatus         String?
  recommendedFor        String?
  avoidFor              String?
  localAvailability     String?
  conventionalTitle     String?
  conventionalHref      String?
  conventionalImageSrc  String?
  conventionalBadge     String?
  conventionalPriceHint String?
  organicTitle          String?
  organicHref           String?
  organicImageSrc       String?
  organicBadge          String?
  organicPriceHint      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  article               Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  product               Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productName])
  @@index([category])
  @@index([productId])
}

model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  websiteUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([name])
}

model Product {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  brandId       String?
  category      String?
  organicStatus String?
  summary       String?
  heroImageUrl  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  brand         Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  inventoryItems InventoryItem[]
  offers         Offer[]
  reviewProfiles ReviewProfile[]
  savedProducts  SavedProduct[]

  @@index([brandId])
  @@index([category])
  @@index([name])
}

model ArticleCommerceModule {
  id                String                     @id @default(cuid())
  articleId         String
  placement         ArticleCommercePlacement
  sortOrder         Int                        @default(0)
  businessId        String?
  businessSlug      String?
  businessName      String?
  offerId           String?
  offerTitle        String?
  inventoryItemId   String?
  inventoryItemName String?
  title             String?
  badgeText         String?
  body              String?
  imageSrc          String?
  imageAlt          String?
  caption           String?
  side              ArticleCommerceSide       @default(RIGHT)
  sizePreset        ArticleCommerceSizePreset @default(FEATURE)
  isEnabled         Boolean                    @default(true)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  article           Article                    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  business          Business?                  @relation(fields: [businessId], references: [id], onDelete: SetNull)
  offer             Offer?                     @relation(fields: [offerId], references: [id], onDelete: SetNull)
  inventoryItem     InventoryItem?             @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([articleId, placement, sortOrder])
  @@index([businessId])
  @@index([offerId])
  @@index([inventoryItemId])
}

model Comment {
  id         String   @id @default(cuid())
  articleId  String
  userId     String?
  authorName String?
  body       String
  createdAt  DateTime @default(now())
  article    Article  @relation(fields: [articleId], references: [id])
  author     User?    @relation(fields: [userId], references: [id])
}

model Reaction {
  id          String        @id @default(cuid())
  articleId   String
  userId      String?
  ipHash      String?
  type        ReactionType
  scope       ReactionScope @default(ARTICLE)
  productSlug String?
  createdAt   DateTime      @default(now())
  article     Article       @relation(fields: [articleId], references: [id])
  user        User?         @relation(fields: [userId], references: [id])

  @@unique([articleId, userId, scope, type])
  @@index([articleId, userId, scope])
  @@index([articleId, scope, type])
  @@index([userId, articleId, scope])
}

model Business {
  id                     String                  @id @default(cuid())
  slug                   String                  @unique
  name                   String
  legalName              String?
  ownerUserId            String?
  contactEmail           String?
  contactPhone           String?
  timezone               String                  @default("America/Edmonton")
  status                 BusinessStatus          @default(ACTIVE)
  isVerified             Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  owner                  User?                   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  storeProfile           StoreProfile?
  inventoryItems         InventoryItem[]
  pricingRules           PricingRule[]
  offers                 Offer[]
  campaigns              Campaign[]
  offerInboxItems        UserOfferInbox[]
  notificationRecipients NotificationRecipient[]
  deliveryLeads          DeliveryLead[]
  affiliateClicks        AffiliateClick[]
  analyticsEvents        AnalyticsEvent[]
  rewardLedgerEntries    RewardLedger[]
  commerceModules        ArticleCommerceModule[]
  fulfillmentAutomationProfile FulfillmentAutomationProfile?
  fulfillmentAutomationRuns    FulfillmentAutomationRun[]
  fulfillmentAutomationAlerts  FulfillmentAutomationAlert[]

  @@index([ownerUserId])
  @@index([status])
}

model FulfillmentAutomationProfile {
  id                      String   @id @default(cuid())
  businessId              String   @unique
  defaultAssigneeUserId   String?
  defaultAssigneeName     String?
  autoAssignEnabled       Boolean  @default(false)
  autoEscalateEnabled     Boolean  @default(false)
  scheduleEnabled         Boolean  @default(false)
  scheduleIntervalHours   Int      @default(6)
  slaHours                Int      @default(24)
  digestEnabled           Boolean  @default(false)
  digestCadenceHours      Int      @default(24)
  escalationCooldownHours Int      @default(6)
  escalationEmail         String?
  digestEmail             String?
  customerContactTemplate String?
  delayUpdateTemplate     String?
  escalationTemplate      String?
  digestTemplate          String?
  lastRunAt               DateTime?
  lastEscalationAt        DateTime?
  lastDigestAt            DateTime?
  lastRunSummary          Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  business                Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  defaultAssignee         User?    @relation("FulfillmentAutomationDefaultAssignee", fields: [defaultAssigneeUserId], references: [id], onDelete: SetNull)
  runs                    FulfillmentAutomationRun[]
  alerts                  FulfillmentAutomationAlert[]

  @@index([defaultAssigneeUserId])
  @@index([lastRunAt])
  @@index([scheduleEnabled, lastRunAt])
  @@index([digestEnabled, lastDigestAt])
}

model FulfillmentAutomationRun {
  id                      String                         @id @default(cuid())
  profileId               String
  businessId              String
  source                  FulfillmentAutomationRunSource @default(MANUAL)
  status                  FulfillmentAutomationRunStatus @default(SUCCESS)
  actorUserId             String?
  actorEmail              String?
  autoAssignedCount       Int                            @default(0)
  overdueLeadCount        Int                            @default(0)
  openLeadCount           Int                            @default(0)
  unassignedLeadCount     Int                            @default(0)
  escalationQueued        Boolean                        @default(false)
  digestQueued            Boolean                        @default(false)
  escalationSkippedReason String?
  digestSkippedReason     String?
  processSummary          Json?
  summary                 Json?
  metadata                Json?
  startedAt               DateTime                       @default(now())
  completedAt             DateTime?
  createdAt               DateTime                       @default(now())
  business                Business                       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  profile                 FulfillmentAutomationProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  alerts                  FulfillmentAutomationAlert[]

  @@index([profileId, startedAt])
  @@index([businessId, startedAt])
  @@index([source, startedAt])
  @@index([status, startedAt])
}

model FulfillmentAutomationAlert {
  id             String                            @id @default(cuid())
  profileId      String
  businessId     String
  runId          String?
  type           FulfillmentAutomationAlertType
  status         FulfillmentAutomationAlertStatus  @default(QUEUED)
  recipientEmail String?
  subject        String?
  leadCount      Int                               @default(0)
  reason         String?
  metadata       Json?
  createdAt      DateTime                          @default(now())
  business       Business                          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  profile        FulfillmentAutomationProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  run            FulfillmentAutomationRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt])
  @@index([businessId, createdAt])
  @@index([type, createdAt])
  @@index([status, createdAt])
}

model StoreProfile {
  id                String   @id @default(cuid())
  businessId        String   @unique
  displayName       String?
  description       String?
  logoUrl           String?
  heroImageUrl      String?
  websiteUrl        String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?
  postalCode        String?
  country           String?
  latitude          Decimal? @db.Decimal(10, 7)
  longitude         Decimal? @db.Decimal(10, 7)
  deliveryRadiusKm  Int?
  pickupEnabled     Boolean  @default(true)
  deliveryEnabled   Boolean  @default(false)
  notificationEmail String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id                String         @id @default(cuid())
  businessId        String
  productId         String?
  sku               String?
  name              String
  description       String?
  category          String?
  unitLabel         String?
  imageUrl          String?
  priceCents        Int
  compareAtCents    Int?
  costCents         Int?
  quantityOnHand    Int            @default(0)
  reservedQuantity  Int            @default(0)
  lowStockThreshold Int?
  expiresAt         DateTime?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  business          Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product           Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  pricingRules      PricingRule[]
  offers            Offer[]
  deliveryLeads     DeliveryLead[]
  analyticsEvents   AnalyticsEvent[]
  commerceModules   ArticleCommerceModule[]

  @@unique([businessId, sku])
  @@index([businessId, isActive])
  @@index([productId])
  @@index([expiresAt])
}

model PricingRule {
  id              String          @id @default(cuid())
  businessId      String
  inventoryItemId String?
  name            String
  description     String?
  ruleType        PricingRuleType @default(PERCENT_OFF)
  priority        Int             @default(100)
  percentOff      Decimal?        @db.Decimal(5, 2)
  amountOffCents  Int?
  fixedPriceCents Int?
  minQuantity     Int?
  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionsUsed Int             @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  offers          Offer[]

  @@index([businessId, isActive])
  @@index([inventoryItemId])
  @@index([startsAt, endsAt])
}

model Offer {
  id                 String         @id @default(cuid())
  businessId         String
  inventoryItemId    String?
  productId          String?
  pricingRuleId      String?
  campaignId         String?
  title              String
  description        String?
  status             OfferStatus    @default(DRAFT)
  badgeText          String?
  couponCode         String?
  discountPriceCents Int?
  startsAt           DateTime?
  endsAt             DateTime?
  unitsTotal         Int?
  unitsClaimed       Int            @default(0)
  ctaUrl             String?
  featured           Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  business           Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryItem      InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  product            Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  pricingRule        PricingRule?   @relation(fields: [pricingRuleId], references: [id], onDelete: SetNull)
  campaign           Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  inboxItems         UserOfferInbox[]
  savedOffers        SavedOffer[]
  deliveryLeads      DeliveryLead[]
  analyticsEvents    AnalyticsEvent[]
  commerceModules    ArticleCommerceModule[]

  @@unique([businessId, couponCode])
  @@index([businessId, status])
  @@index([productId])
  @@index([startsAt, endsAt])
  @@index([featured])
}

model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
  @@index([productId, createdAt])
}

model SavedOffer {
  id        String   @id @default(cuid())
  userId    String
  offerId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([userId, createdAt])
  @@index([offerId, createdAt])
}

model UserOfferInbox {
  id                 String              @id @default(cuid())
  userExternalId     String
  userEmail          String
  userName           String?
  offerId            String
  businessId         String
  assignedByExternal String?
  assignedByEmail    String?
  assignmentMode     OfferAssignmentMode @default(DIRECT)
  status             OfferInboxStatus    @default(ACTIVE)
  assignedAt         DateTime            @default(now())
  seenAt             DateTime?
  redeemedAt         DateTime?
  expiresAt          DateTime?
  metadata           Json?
  offer              Offer               @relation(fields: [offerId], references: [id], onDelete: Cascade)
  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userExternalId, offerId])
  @@index([userExternalId, status, assignedAt])
  @@index([userEmail, status, assignedAt])
  @@index([businessId, status, assignedAt])
  @@index([offerId, status])
}

model Campaign {
  id                  String           @id @default(cuid())
  businessId          String
  name                String
  description         String?
  type                CampaignType     @default(PROMOTION)
  status              CampaignStatus   @default(DRAFT)
  startsAt            DateTime?
  endsAt              DateTime?
  geofenceLatitude    Decimal?         @db.Decimal(10, 7)
  geofenceLongitude   Decimal?         @db.Decimal(10, 7)
  geofenceRadiusM     Int?
  budgetCents         Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  business            Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  offers              Offer[]
  affiliateClicks     AffiliateClick[]
  analyticsEvents     AnalyticsEvent[]
  rewardLedgerEntries RewardLedger[]

  @@index([businessId, status])
  @@index([type])
  @@index([startsAt, endsAt])
}

model NotificationRecipient {
  id               String              @id @default(cuid())
  businessId       String
  userId           String?
  name             String?
  email            String?
  phone            String?
  pushToken        String?
  preferredChannel NotificationChannel @default(EMAIL)
  emailOptIn       Boolean             @default(true)
  smsOptIn         Boolean             @default(false)
  pushOptIn        Boolean             @default(false)
  tags             Json?
  lastNotifiedAt   DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  business         Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveryLeads    DeliveryLead[]

  @@unique([businessId, email])
  @@unique([businessId, phone])
  @@index([businessId])
  @@index([userId])
}

model DeliveryLead {
  id              String                 @id @default(cuid())
  businessId      String
  inventoryItemId String?
  offerId         String?
  recipientId     String?
  userId          String?
  assignedToUserId String?
  assignedAt      DateTime?
  assignedToName  String?
  source          DeliveryLeadSource     @default(ARTICLE_CTA)
  status          DeliveryLeadStatus     @default(NEW)
  requestedQty    Int                    @default(1)
  unitPriceCents  Int?
  totalCents      Int?
  requestedAt     DateTime               @default(now())
  fulfillBy       DateTime?
  contactedAt     DateTime?
  fulfilledAt     DateTime?
  cancelledAt     DateTime?
  deliveryAddress String?
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  business        Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem?         @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  offer           Offer?                 @relation(fields: [offerId], references: [id], onDelete: SetNull)
  recipient       NotificationRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignee        User?                  @relation("DeliveryLeadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([assignedToUserId, status])
  @@index([requestedAt])
  @@index([offerId])
  @@index([recipientId])
}

model AffiliateClick {
  id             String           @id @default(cuid())
  businessId     String?
  campaignId     String?
  articleId      String?
  userId         String?
  network        AffiliateNetwork @default(AMAZON)
  sourceContext  String?
  destinationUrl String
  referrerUrl    String?
  ipHash         String?
  userAgent      String?
  createdAt      DateTime         @default(now())
  business       Business?        @relation(fields: [businessId], references: [id], onDelete: SetNull)
  campaign       Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  article        Article?         @relation(fields: [articleId], references: [id], onDelete: SetNull)
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([network, createdAt])
  @@index([businessId])
  @@index([campaignId])
  @@index([articleId])
  @@index([userId])
}

model SubscriptionEntitlement {
  id                   String             @id @default(cuid())
  userExternalId       String?            @unique
  userEmail            String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(NONE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeProductId      String?
  checkoutSessionId    String?
  latestInvoiceId      String?
  cancelAtPeriodEnd    Boolean            @default(false)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  syncedAt             DateTime?
  mismatchReason       String?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userEmail])
  @@index([plan])
  @@index([status])
  @@index([currentPeriodEnd])
}

model AnalyticsEvent {
  id              String             @id @default(cuid())
  eventType       AnalyticsEventType
  articleId       String?
  businessId      String?
  campaignId      String?
  offerId         String?
  inventoryItemId String?
  userId          String?
  sessionId       String?
  sourceContext   String?
  adSlot          String?
  channel         NotificationChannel?
  destinationUrl  String?
  referrerUrl     String?
  ipHash          String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime           @default(now())
  article         Article?           @relation(fields: [articleId], references: [id], onDelete: SetNull)
  business        Business?          @relation(fields: [businessId], references: [id], onDelete: SetNull)
  campaign        Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  offer           Offer?             @relation(fields: [offerId], references: [id], onDelete: SetNull)
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([articleId, createdAt])
  @@index([businessId, createdAt])
  @@index([campaignId, createdAt])
  @@index([offerId, createdAt])
  @@index([inventoryItemId, createdAt])
  @@index([userId, createdAt])
}

model RewardLedger {
  id          String          @id @default(cuid())
  businessId  String?
  campaignId  String?
  userId      String?
  token       RewardToken
  direction   RewardDirection @default(CREDIT)
  amount      Decimal         @db.Decimal(20, 8)
  reason      String
  metadata    Json?
  externalRef String?         @unique
  createdAt   DateTime        @default(now())
  business    Business?       @relation(fields: [businessId], references: [id], onDelete: SetNull)
  campaign    Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, token, createdAt])
  @@index([businessId, token, createdAt])
  @@index([campaignId, createdAt])
}

model AuthRegistrationEvent {
  id             String                 @id @default(cuid())
  userId         String?
  email          String?
  method         AuthProvider
  status         AuthRegistrationStatus
  failureCode    String?
  failureMessage String?
  ipHash         String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime               @default(now())
  user           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([method, status, createdAt])
  @@index([email, createdAt])
  @@index([userId, createdAt])
}

model AuthFunnelEvent {
  id            String          @id @default(cuid())
  stage         AuthFunnelStage
  method        AuthProvider?
  userId        String?
  email         String?
  sessionId     String?
  sourceContext String?
  metadata      Json?
  createdAt     DateTime        @default(now())
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([stage, createdAt])
  @@index([method, stage, createdAt])
  @@index([userId, stage, createdAt])
  @@index([email, stage, createdAt])
  @@index([sessionId, stage, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispatches PasswordResetDispatch[]

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([expiresAt])
}

model PasswordResetDispatch {
  id                String                    @id @default(cuid())
  passwordResetTokenId String?
  userId            String
  email             String
  source            PasswordResetDispatchSource
  provider          String
  delivered         Boolean
  reason            String?
  requestedByUserId String?
  requestedByEmail  String?
  metadata          Json?
  createdAt         DateTime                  @default(now())
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordResetToken PasswordResetToken?      @relation(fields: [passwordResetTokenId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([source, delivered, createdAt])
  @@index([createdAt])
}

model IdentityAutoHealRun {
  id                 String   @id @default(cuid())
  actorUserId        String?
  actorEmail         String?
  mode               String   @default("manual")
  wsApiAvailable     Boolean
  scannedCount       Int
  roleMismatchBefore Int
  roleMismatchAfter  Int
  localOnlyCount     Int
  wsApiOnlyCount     Int
  wsApiRoleUpdated   Int      @default(0)
  localUsersCreated  Int      @default(0)
  warnings           Json?
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([mode, createdAt])
}

model PublicSurfaceProbeRun {
  id                    String   @id @default(cuid())
  actorUserId           String?
  actorEmail            String?
  origin                String
  homeUrl               String
  apexUrl               String
  socialImageUrl        String
  xCardBypassUrl        String
  homeStatus            Int?
  apexStatus            Int?
  socialImageStatus     Int?
  homeRedirectedTo      String?
  apexRedirectedTo      String?
  socialImageContentType String?
  hasOgImage            Boolean
  hasTwitterCard        Boolean
  hasSummaryLargeImage  Boolean
  snapshot              Json
  createdAt             DateTime @default(now())

  @@index([createdAt])
  @@index([origin, createdAt])
}

model AccountRescueRun {
  id                      String   @id @default(cuid())
  actorUserId             String?
  actorEmail              String?
  targetUserId            String?
  targetEmail             String
  wsApiAvailable          Boolean
  localPasswordUpdated    Boolean
  wsApiPasswordUpdated    Boolean
  resetDispatchDelivered  Boolean
  resetDispatchProvider   String
  resetDispatchReason     String?
  warnings                Json?
  createdAt               DateTime @default(now())

  @@index([targetEmail, createdAt])
  @@index([createdAt])
}

